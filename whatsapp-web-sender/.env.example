# WhatsApp Web Sender — Variables de entorno
# Copiar como .env y configurar

# Puerto del servidor (default: 3099)
PORT=3099

# API Key para autenticar las requests desde otras apps
# Cambiar esto en producción
WA_API_KEY=tulkas-wa-2026

# Headless mode:
# false = abre el browser visible (para escanear QR en desarrollo)
# true  = sin UI (para Railway/servidor)
HEADLESS=false
